<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FAF3E0">

    <!-- Top Bar -->
    <ImageView
        android:id="@+id/logo"
        android:layout_width="100dp"
        android:layout_height="40dp"
        android:layout_marginStart="16dp"
        android:layout_marginTop="16dp"
        android:src="@android:drawable/ic_menu_gallery"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <Button
        android:id="@+id/btnUpgrade"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginEnd="16dp"
        android:backgroundTint="#FF7043"
        android:text="@string/upgrade"
        android:textSize="12sp"
        app:layout_constraintBottom_toBottomOf="@+id/logo"
        app:layout_constraintEnd_toStartOf="@+id/profile_icon"
        app:layout_constraintTop_toTopOf="@+id/logo" />

    <View
        android:id="@+id/profile_icon"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:layout_marginEnd="16dp"
        android:background="@android:color/holo_purple"
        app:layout_constraintBottom_toBottomOf="@+id/logo"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@+id/logo" />

    <!-- Tabs -->
    <LinearLayout
        android:id="@+id/tab_layout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:orientation="horizontal"
        app:layout_constraintTop_toBottomOf="@+id/logo">

        <!-- Sách nói Tab -->
        <LinearLayout
            android:id="@+id/tab_audiobooks_container"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true">
            <TextView
                android:id="@+id/tvTabAudiobooks"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:padding="8dp"
                android:text="@string/tab_audiobooks"
                android:textColor="@android:color/black"
                android:textStyle="bold" />
            <View
                android:id="@+id/indicator_audiobooks"
                android:layout_width="40dp"
                android:layout_height="3dp"
                android:background="#FF7043"
                android:visibility="visible" />
        </LinearLayout>

        <!-- Ebook Tab -->
        <LinearLayout
            android:id="@+id/tab_ebook_container"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true">
            <TextView
                android:id="@+id/tvTabEbook"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:padding="8dp"
                android:text="@string/tab_ebook"
                android:textColor="@android:color/darker_gray" />
            <View
                android:id="@+id/indicator_ebook"
                android:layout_width="40dp"
                android:layout_height="3dp"
                android:background="#FF7043"
                android:visibility="invisible" />
        </LinearLayout>

        <!-- Tóm tắt sách Tab -->
        <LinearLayout
            android:id="@+id/tab_summary_container"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true">
            <TextView
                android:id="@+id/tvTabSummary"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:padding="8dp"
                android:text="@string/tab_summary"
                android:textColor="@android:color/darker_gray" />
            <View
                android:id="@+id/indicator_summary"
                android:layout_width="40dp"
                android:layout_height="3dp"
                android:background="#FF7043"
                android:visibility="invisible" />
        </LinearLayout>
    </LinearLayout>

    <!-- Main Content Scroll -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintBottom_toTopOf="@+id/bottom_nav"
        app:layout_constraintTop_toBottomOf="@+id/tab_layout">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:id="@+id/tvBestSellersHeader"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:text="Top Sách Nói Thịnh Hành"
                android:textColor="#1A237E"
                android:textSize="20sp"
                android:textStyle="bold"
                android:visibility="gone" />

            <!-- Best Seller Carousel -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvBestSellers"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:clipToPadding="false"
                android:nestedScrollingEnabled="false"
                android:paddingHorizontal="32dp" />

            <!-- Categories (Danh Mục) Section -->
            <LinearLayout
                android:id="@+id/layoutCategories"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginTop="24dp"
                android:visibility="gone">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="12dp">
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Danh Mục"
                        android:textColor="#142B4A"
                        android:textSize="20sp"
                        android:textStyle="bold" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="›"
                        android:textColor="#FF7043"
                        android:textSize="24sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <HorizontalScrollView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:scrollbars="none">

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="💪 Kỹ năng"
                            android:background="@drawable/bg_category_chip"
                            android:textColor="#142B4A"
                            android:textSize="14sp"
                            android:paddingHorizontal="16dp"
                            android:paddingVertical="10dp"
                            android:layout_marginEnd="8dp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="🤔 Tư duy"
                            android:background="@drawable/bg_category_chip"
                            android:textColor="#142B4A"
                            android:textSize="14sp"
                            android:paddingHorizontal="16dp"
                            android:paddingVertical="10dp"
                            android:layout_marginEnd="8dp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="📜 Văn học"
                            android:background="@drawable/bg_category_chip"
                            android:textColor="#142B4A"
                            android:textSize="14sp"
                            android:paddingHorizontal="16dp"
                            android:paddingVertical="10dp"
                            android:layout_marginEnd="8dp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="👩‍🍼 Nuôi dạy con"
                            android:background="@drawable/bg_category_chip"
                            android:textColor="#142B4A"
                            android:textSize="14sp"
                            android:paddingHorizontal="16dp"
                            android:paddingVertical="10dp"
                            android:layout_marginEnd="8dp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="👶 Thiếu nhi"
                            android:background="@drawable/bg_category_chip"
                            android:textColor="#142B4A"
                            android:textSize="14sp"
                            android:paddingHorizontal="16dp"
                            android:paddingVertical="10dp"
                            android:layout_marginEnd="8dp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="🤝 Kinh doanh"
                            android:background="@drawable/bg_category_chip"
                            android:textColor="#142B4A"
                            android:textSize="14sp"
                            android:paddingHorizontal="16dp"
                            android:paddingVertical="10dp" />

                    </LinearLayout>
                </HorizontalScrollView>
            </LinearLayout>

            <TextView
                android:id="@+id/tvBooksForYouTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="@string/books_for_you_title"
                android:textColor="#1A237E"
                android:textSize="20sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvBooksForYouSubtitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/books_for_you_subtitle"
                android:textColor="@android:color/darker_gray"
                android:textSize="14sp" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvBooks"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:nestedScrollingEnabled="false" />

        </LinearLayout>
    </ScrollView>

    <!-- Bottom Nav -->
    <LinearLayout
        android:id="@+id/bottom_nav"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:background="@android:color/white"
        android:orientation="horizontal"
        app:layout_constraintBottom_toBottomOf="parent">

        <TextView
            android:id="@+id/navBooks"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:text="@string/fonos_nav_books"
            android:textColor="#FF7043"
            android:textSize="10sp" />

        <TextView
            android:id="@+id/navExplore"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:text="@string/fonos_nav_explore"
            android:textSize="10sp" />

        <TextView
            android:id="@+id/navLibrary"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:text="@string/fonos_nav_library"
            android:textSize="10sp" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>