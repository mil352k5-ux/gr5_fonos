<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8FAFC">

    <!-- Top Bar (Soundwave Logo + Profile Circle) -->
    <LinearLayout
        android:id="@+id/logo_layout"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_marginTop="16dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <!-- Soundwave vertical bars -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginEnd="8dp">
            <View
                android:layout_width="3.5dp"
                android:layout_height="14dp"
                android:background="#FF7043"
                android:layout_margin="1.5dp"/>
            <View
                android:layout_width="3.5dp"
                android:layout_height="24dp"
                android:background="#FF7043"
                android:layout_margin="1.5dp"/>
            <View
                android:layout_width="3.5dp"
                android:layout_height="32dp"
                android:background="#FF7043"
                android:layout_margin="1.5dp"/>
            <View
                android:layout_width="3.5dp"
                android:layout_height="18dp"
                android:background="#FF7043"
                android:layout_margin="1.5dp"/>
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="fonos"
            android:textColor="#0C1D37"
            android:textSize="24sp"
            android:textStyle="bold"
            android:letterSpacing="-0.02"/>
    </LinearLayout>

    <!-- Profile Circle 'T' with Premium Gradient -->
    <androidx.cardview.widget.CardView
        android:id="@+id/profile_icon"
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:layout_marginEnd="16dp"
        app:cardCornerRadius="18dp"
        app:cardElevation="3dp"
        app:layout_constraintBottom_toBottomOf="@+id/logo_layout"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@+id/logo_layout">
        <View
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@drawable/gradient_upgrade" />
        <TextView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:text="T"
            android:textColor="@android:color/white"
            android:textSize="16sp"
            android:textStyle="bold"
            android:gravity="center" />
    </androidx.cardview.widget.CardView>

    <!-- Tabs Container (White elevated bar) -->
    <LinearLayout
        android:id="@+id/tab_layout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:orientation="horizontal"
        android:background="#FFFFFF"
        android:paddingVertical="4dp"
        app:layout_constraintTop_toBottomOf="@+id/logo_layout">

        <!-- Sách nói Tab -->
        <LinearLayout
            android:id="@+id/tab_audiobooks_container"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true"
            android:paddingVertical="8dp">
            <TextView
                android:id="@+id/tvTabAudiobooks"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Sách nói"
                android:textColor="#0C1D37"
                android:textSize="15sp"
                android:textStyle="bold" />
            <View
                android:id="@+id/indicator_audiobooks"
                android:layout_width="45dp"
                android:layout_height="3dp"
                android:layout_marginTop="6dp"
                android:background="@drawable/bg_tab_indicator"
                android:visibility="visible" />
        </LinearLayout>

        <!-- Ebook Tab -->
        <LinearLayout
            android:id="@+id/tab_ebook_container"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true"
            android:paddingVertical="8dp">
            <TextView
                android:id="@+id/tvTabEbook"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Ebook"
                android:textColor="#757575"
                android:textSize="15sp" />
            <View
                android:id="@+id/indicator_ebook"
                android:layout_width="45dp"
                android:layout_height="3dp"
                android:layout_marginTop="6dp"
                android:background="@drawable/bg_tab_indicator"
                android:visibility="invisible" />
        </LinearLayout>

    </LinearLayout>

    <View
        android:id="@+id/tab_divider"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#E2E8F0"
        app:layout_constraintTop_toBottomOf="@+id/tab_layout"/>

    <!-- Scrollable Main Content -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:fillViewport="true"
        android:scrollbars="none"
        app:layout_constraintBottom_toTopOf="@+id/mini_player_container"
        app:layout_constraintTop_toBottomOf="@+id/tab_divider">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="24dp">

            <!-- Welcome Greeting Banner -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardWelcomeBanner"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="16dp"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="8dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="6dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/gradient_upgrade"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Chào bạn, nghe gì hôm nay?"
                        android:textColor="#FFFFFF"
                        android:textSize="18sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:text="Hàng ngàn cuốn sách nói chất lượng cao đang chờ đón bạn khám phá."
                        android:textColor="#E2E8F0"
                        android:textSize="13sp" />

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Title for Best Seller Section -->
            <TextView
                android:id="@+id/tvBestSellersHeader"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_marginTop="20dp"
                android:layout_marginBottom="8dp"
                android:text="Sách Nói Thịnh Hành"
                android:textColor="#0C1D37"
                android:textSize="18sp"
                android:textStyle="bold"
                android:visibility="visible" />

            <!-- Best Seller Slider Carousel -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvBestSellers"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:clipToPadding="false"
                android:nestedScrollingEnabled="false"
                android:paddingHorizontal="8dp" />

            <!-- Categories Horizontal scrolling chips -->
            <LinearLayout
                android:id="@+id/layoutCategories"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginTop="20dp"
                android:visibility="gone">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginStart="16dp"
                    android:layout_marginEnd="16dp"
                    android:layout_marginBottom="12dp">
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Danh Mục"
                        android:textColor="#0C1D37"
                        android:textSize="18sp"
                        android:textStyle="bold" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="›"
                        android:textColor="#FF7043"
                        android:textSize="24sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <HorizontalScrollView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:scrollbars="none"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp">

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <TextView
                            android:id="@+id/chipKyNang"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="💪 Kỹ năng"
                            android:background="@drawable/bg_category_chip"
                            android:textColor="#1E293B"
                            android:textSize="14sp"
                            android:paddingHorizontal="16dp"
                            android:paddingVertical="9dp"
                            android:layout_marginEnd="8dp"
                            android:clickable="true"
                            android:focusable="true"/>

                        <TextView
                            android:id="@+id/chipTuDuy"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="🤔 Tư duy"
                            android:background="@drawable/bg_category_chip"
                            android:textColor="#1E293B"
                            android:textSize="14sp"
                            android:paddingHorizontal="16dp"
                            android:paddingVertical="9dp"
                            android:layout_marginEnd="8dp"
                            android:clickable="true"
                            android:focusable="true"/>

                        <TextView
                            android:id="@+id/chipVanHoc"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="📜 Văn học"
                            android:background="@drawable/bg_category_chip"
                            android:textColor="#1E293B"
                            android:textSize="14sp"
                            android:paddingHorizontal="16dp"
                            android:paddingVertical="9dp"
                            android:layout_marginEnd="8dp"
                            android:clickable="true"
                            android:focusable="true"/>

                        <TextView
                            android:id="@+id/chipNuoiDayCon"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="👩‍🍼 Nuôi dạy con"
                            android:background="@drawable/bg_category_chip"
                            android:textColor="#1E293B"
                            android:textSize="14sp"
                            android:paddingHorizontal="16dp"
                            android:paddingVertical="9dp"
                            android:layout_marginEnd="8dp"
                            android:clickable="true"
                            android:focusable="true"/>

                        <TextView
                            android:id="@+id/chipThieuNhi"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="👶 Thiếu nhi"
                            android:background="@drawable/bg_category_chip"
                            android:textColor="#1E293B"
                            android:textSize="14sp"
                            android:paddingHorizontal="16dp"
                            android:paddingVertical="9dp"
                            android:layout_marginEnd="8dp"
                            android:clickable="true"
                            android:focusable="true"/>

                        <TextView
                            android:id="@+id/chipKinhDoanh"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="🤝 Kinh doanh"
                            android:background="@drawable/bg_category_chip"
                            android:textColor="#1E293B"
                            android:textSize="14sp"
                            android:paddingHorizontal="16dp"
                            android:paddingVertical="9dp"
                            android:clickable="true"
                            android:focusable="true"/>

                    </LinearLayout>
                </HorizontalScrollView>
            </LinearLayout>

            <!-- Main Books List Header -->
            <TextView
                android:id="@+id/tvBooksForYouTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_marginTop="24dp"
                android:text="Sách Nói Dành Cho Bạn"
                android:textColor="#0C1D37"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvBooksForYouSubtitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_marginTop="2dp"
                android:text="Phù hợp với người mới – bấm để nghe ngay"
                android:textColor="#757575"
                android:textSize="13sp" />

            <!-- Main Horizontal List of Books -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvBooks"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:clipToPadding="false"
                android:nestedScrollingEnabled="false" />

        </LinearLayout>
    </ScrollView>

    <!-- Bottom Navigation Bar (Elevated white layout) -->
    <LinearLayout
        android:id="@+id/bottom_nav"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:background="#FFFFFF"
        android:elevation="8dp"
        android:orientation="horizontal"
        app:layout_constraintBottom_toBottomOf="parent">

        <LinearLayout
            android:id="@+id/navBooks"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical"
            android:clickable="true"
            android:focusable="true">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="📖"
                android:textSize="20sp"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Sách"
                android:textColor="#FF7043"
                android:textStyle="bold"
                android:textSize="11sp"
                android:layout_marginTop="2dp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/navExplore"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical"
            android:clickable="true"
            android:focusable="true">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🔍"
                android:textSize="20sp"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Khám phá"
                android:textColor="#7E8A9A"
                android:textSize="11sp"
                android:layout_marginTop="2dp" />
        </LinearLayout>


        <LinearLayout
            android:id="@+id/navLibrary"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical"
            android:clickable="true"
            android:focusable="true">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="📚"
                android:textSize="20sp"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Thư viện"
                android:textColor="#7E8A9A"
                android:textSize="11sp"
                android:layout_marginTop="2dp" />
        </LinearLayout>
    </LinearLayout>

    <!-- Floating Mini Player -->
    <include layout="@layout/layout_mini_player" />

</androidx.constraintlayout.widget.ConstraintLayout>