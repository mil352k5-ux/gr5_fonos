<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F8FA"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- TOP SECTION WITH GRADIENT BACKGROUND -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/gradient_detail_header"
            android:orientation="vertical"
            android:paddingStart="24dp"
            android:paddingEnd="24dp"
            android:paddingTop="24dp"
            android:paddingBottom="36dp">

            <!-- HEADER BAR: BACK AND SHARE -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <TextView
                    android:id="@+id/tvBack"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:background="@drawable/circle_background_trans"
                    android:gravity="center"
                    android:text="‹"
                    android:textColor="#FFFFFF"
                    android:textSize="28sp"
                    android:textStyle="bold" />

                <ImageView
                    android:id="@+id/btnShare"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:layout_alignParentEnd="true"
                    android:background="@drawable/circle_background_trans"
                    android:padding="8dp"
                    android:src="@android:drawable/ic_menu_share"
                    android:tint="#FFFFFF" />
            </RelativeLayout>

            <!-- BOOK COVER -->
            <androidx.cardview.widget.CardView
                android:layout_width="160dp"
                android:layout_height="230dp"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="16dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="8dp"
                app:cardBackgroundColor="#DDE6EF">

                <ImageView
                    android:id="@+id/imgBookCover"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="centerCrop" />
            </androidx.cardview.widget.CardView>

            <!-- TITLE -->
            <TextView
                android:id="@+id/tvBookTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:gravity="center"
                android:textColor="#FFFFFF"
                android:textSize="22sp"
                android:textStyle="bold" />

            <!-- AUTHOR -->
            <TextView
                android:id="@+id/tvBookAuthor"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:gravity="center"
                android:textColor="#DDEEBC"
                android:textSize="15sp"
                android:textStyle="bold" />

            <!-- TRENDING BADGE -->
            <TextView
                android:id="@+id/tvTrendingBadge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_badge_popular"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:paddingTop="4dp"
                android:paddingBottom="4dp"
                android:text="#5 THỊNH HÀNH"
                android:textColor="#FFFFFF"
                android:textSize="12sp"
                android:textStyle="bold" />

            <!-- INTERACTIVE BUTTONS -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/btnFavorite"
                    android:layout_width="52dp"
                    android:layout_height="52dp"
                    android:background="@drawable/circle_background_trans"
                    android:gravity="center"
                    android:text="♡"
                    android:textColor="#FFFFFF"
                    android:textSize="26sp" />

                <TextView
                    android:id="@+id/tvListenNow"
                    android:layout_width="0dp"
                    android:layout_height="52dp"
                    android:layout_marginStart="16dp"
                    android:layout_weight="1"
                    android:background="@drawable/button_rounded_white"
                    android:gravity="center"
                    android:text="▶ Nghe chương đầu miễn phí"
                    android:textColor="#3E4B27"
                    android:textSize="16sp"
                    android:textStyle="bold" />
            </LinearLayout>

        </LinearLayout>

        <!-- BOTTOM CONTAINER WITH OVERLAP -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/white_top_rounded"
            android:layout_marginTop="-16dp"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- 3-COLUMN STATS CARD -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_stats_container"
                android:padding="12dp"
                android:orientation="horizontal"
                android:weightSum="3">

                <!-- Rating -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="⭐⭐⭐⭐⭐"
                        android:textSize="11sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:text="4.7 / 5.0"
                        android:textColor="#142B4A"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="322 đánh giá"
                        android:textColor="#7E8A9A"
                        android:textSize="11sp" />
                </LinearLayout>

                <View
                    android:layout_width="1dp"
                    android:layout_height="match_parent"
                    android:background="#DDE6EF" />

                <!-- Category/Ranking -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Xếp hạng"
                        android:textColor="#7E8A9A"
                        android:textSize="11sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:text="#3"
                        android:textColor="#142B4A"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvBookCategory"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="#7E8A9A"
                        android:text="Kỹ năng"
                        android:textSize="11sp" />
                </LinearLayout>

                <View
                    android:layout_width="1dp"
                    android:layout_height="match_parent"
                    android:background="#DDE6EF" />

                <!-- Duration -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Thời gian"
                        android:textColor="#7E8A9A"
                        android:textSize="11sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:text="🕐"
                        android:textSize="14sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="8 giờ 33 phút"
                        android:textColor="#7E8A9A"
                        android:textSize="11sp" />
                </LinearLayout>
            </LinearLayout>

            <!-- DESCRIPTION -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:text="Giới thiệu"
                android:textColor="#142B4A"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvBookDescription"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:textColor="#4A5F7A"
                android:textSize="14sp"
                android:lineSpacingExtra="4dp" />

            <TextView
                android:id="@+id/tvSeeMore"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Xem thêm"
                android:textColor="#FF7043"
                android:textSize="14sp"
                android:textStyle="bold" />

            <!-- CATEGORY CHIPS -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_category_chip"
                    android:paddingHorizontal="12dp"
                    android:paddingVertical="6dp"
                    android:text="Kỹ năng"
                    android:textColor="#4A5F7A"
                    android:textSize="12sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:background="@drawable/bg_category_chip"
                    android:paddingHorizontal="12dp"
                    android:paddingVertical="6dp"
                    android:text="Kỹ năng giao tiếp"
                    android:textColor="#4A5F7A"
                    android:textSize="12sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:background="@drawable/bg_category_chip"
                    android:paddingHorizontal="12dp"
                    android:paddingVertical="6dp"
                    android:ellipsize="end"
                    android:maxLines="1"
                    android:text="Thuyết trình &amp; Giao tiếp"
                    android:textColor="#4A5F7A"
                    android:textSize="12sp" />
            </LinearLayout>

            <!-- REVIEWS HEADER -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="Nhận xét &amp; Đánh giá"
                android:textColor="#142B4A"
                android:textSize="18sp"
                android:textStyle="bold" />

            <!-- REVIEWS CARD OVERVIEW -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="#FFFFFF">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="16dp">

                    <!-- RATING DETAIL -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:gravity="center_vertical"
                            android:orientation="horizontal">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="⭐"
                                android:textSize="16sp" />
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="4dp"
                                android:text="4.7"
                                android:textColor="#142B4A"
                                android:textSize="22sp"
                                android:textStyle="bold" />
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="/5.0"
                                android:textColor="#7E8A9A"
                                android:textSize="14sp" />
                        </LinearLayout>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="(322 đánh giá)"
                            android:textColor="#7E8A9A"
                            android:textSize="12sp" />

                        <!-- PROGRESS BARS -->
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="12dp"
                            android:text="Nội dung"
                            android:textColor="#7E8A9A"
                            android:textSize="11sp" />
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center_vertical"
                            android:orientation="horizontal">
                            <ProgressBar
                                style="?android:attr/progressBarStyleHorizontal"
                                android:layout_width="0dp"
                                android:layout_height="6dp"
                                android:layout_weight="1"
                                android:progress="94"
                                android:progressTint="#FF7043" />
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="8dp"
                                android:text="4.7/5.0"
                                android:textColor="#142B4A"
                                android:textSize="11sp"
                                android:textStyle="bold" />
                        </LinearLayout>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:text="Giọng đọc"
                            android:textColor="#7E8A9A"
                            android:textSize="11sp" />
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center_vertical"
                            android:orientation="horizontal">
                            <ProgressBar
                                style="?android:attr/progressBarStyleHorizontal"
                                android:layout_width="0dp"
                                android:layout_height="6dp"
                                android:layout_weight="1"
                                android:progress="94"
                                android:progressTint="#FF7043" />
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="8dp"
                                android:text="4.7/5.0"
                                android:textColor="#142B4A"
                                android:textSize="11sp"
                                android:textStyle="bold" />
                        </LinearLayout>

                    </LinearLayout>

                    <!-- MINI COVER -->
                    <ImageView
                        android:id="@+id/imgMiniCover"
                        android:layout_width="60dp"
                        android:layout_height="90dp"
                        android:layout_gravity="center_vertical"
                        android:layout_marginStart="16dp"
                        android:background="#DDE6EF"
                        android:scaleType="centerCrop" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- WRITE A REVIEW CARD -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cvWriteReview"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="#FFFFFF">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Viết nhận xét &amp; đánh giá của bạn"
                        android:textColor="#142B4A"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="12dp" />

                    <!-- Custom Star Selection -->
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="12dp">
                        
                        <TextView
                            android:id="@+id/tvStar1"
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:text="☆"
                            android:textColor="#FFB300"
                            android:textSize="24sp"
                            android:gravity="center"
                            android:clickable="true"
                            android:focusable="true" />
                        <TextView
                            android:id="@+id/tvStar2"
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:text="☆"
                            android:textColor="#FFB300"
                            android:textSize="24sp"
                            android:gravity="center"
                            android:clickable="true"
                            android:focusable="true" />
                        <TextView
                            android:id="@+id/tvStar3"
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:text="☆"
                            android:textColor="#FFB300"
                            android:textSize="24sp"
                            android:gravity="center"
                            android:clickable="true"
                            android:focusable="true" />
                        <TextView
                            android:id="@+id/tvStar4"
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:text="☆"
                            android:textColor="#FFB300"
                            android:textSize="24sp"
                            android:gravity="center"
                            android:clickable="true"
                            android:focusable="true" />
                        <TextView
                            android:id="@+id/tvStar5"
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:text="☆"
                            android:textColor="#FFB300"
                            android:textSize="24sp"
                            android:gravity="center"
                            android:clickable="true"
                            android:focusable="true" />
                    </LinearLayout>

                    <EditText
                        android:id="@+id/etReviewContent"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:minHeight="80dp"
                        android:background="@drawable/edit_text_rounded_light"
                        android:hint="Chia sẻ cảm nghĩ của bạn về cuốn sách này..."
                        android:textColorHint="#94A3B8"
                        android:textColor="#142B4A"
                        android:textSize="13sp"
                        android:gravity="top|start"
                        android:padding="10dp"
                        android:inputType="textMultiLine"
                        android:layout_marginBottom="12dp" />

                    <Button
                        android:id="@+id/btnSubmitReview"
                        android:layout_width="wrap_content"
                        android:layout_height="40dp"
                        android:layout_gravity="end"
                        android:background="@drawable/button_rounded_orange"
                        android:text="Gửi đánh giá"
                        android:textColor="#FFFFFF"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:paddingHorizontal="16dp" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- CONTAINER FOR DYNAMIC REVIEWS -->
            <LinearLayout
                android:id="@+id/llReviewsList"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <!-- INITIAL HARDCODED REVIEW -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:background="@drawable/bg_review_card"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <TextView
                            android:layout_width="36dp"
                            android:layout_height="36dp"
                            android:background="@drawable/circle_background"
                            android:gravity="center"
                            android:text="👨‍🚀"
                            android:textSize="20sp" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="10dp"
                            android:layout_weight="1"
                            android:orientation="vertical">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Đạt"
                                android:textColor="#142B4A"
                                android:textSize="14sp"
                                android:textStyle="bold" />
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="4 năm trước"
                                android:textColor="#7E8A9A"
                                android:textSize="11sp" />
                        </LinearLayout>
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="⭐ 5/5"
                            android:textColor="#FFB300"
                            android:textSize="13sp"
                            android:textStyle="bold" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="8dp"
                            android:text="Rất hay"
                            android:textColor="#142B4A"
                            android:textSize="14sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:text="Sách nói rất bổ ích, giọng đọc diễn cảm, dễ nghe và dễ ngấm."
                        android:textColor="#4A5F7A"
                        android:textSize="13sp" />
                </LinearLayout>

            </LinearLayout>

        </LinearLayout>

    </LinearLayout>
</ScrollView>