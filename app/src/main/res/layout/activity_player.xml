<?xml version="1.0" encoding="utf-8"?>

<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/playerRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#123A63"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="24dp"
        android:paddingTop="24dp"
        android:paddingEnd="24dp"
        android:paddingBottom="28dp">

        <!-- TOP BAR -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/tvClosePlayer"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:background="#2D5578"
                android:gravity="center"
                android:text="⌄"
                android:textColor="#FFFFFF"
                android:textSize="34sp"
                android:textStyle="bold" />

            <View
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1" />

            <TextView
                android:id="@+id/tvBookmark"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:background="#2D5578"
                android:gravity="center"
                android:text="♡"
                android:textColor="#FFFFFF"
                android:textSize="28sp"
                android:textStyle="bold" />

        </LinearLayout>

        <!-- BOOK COVER -->
        <ImageView
            android:id="@+id/imgPlayerCover"
            android:layout_width="250dp"
            android:layout_height="340dp"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="26dp"
            android:background="#DDE6EF"
            android:elevation="8dp"
            android:scaleType="centerCrop" />

        <!-- TITLE -->
        <TextView
            android:id="@+id/tvPlayerTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="30dp"
            android:ellipsize="end"
            android:gravity="center"
            android:maxLines="2"
            android:text="Tên sách"
            android:textColor="#FFFFFF"
            android:textSize="30sp"
            android:textStyle="bold" />

        <!-- AUTHOR -->
        <TextView
            android:id="@+id/tvPlayerAuthor"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:ellipsize="end"
            android:gravity="center"
            android:maxLines="1"
            android:text="Tác giả"
            android:textColor="#AFC7E4"
            android:textSize="18sp"
            android:textStyle="bold" />

        <!-- STATUS -->
        <TextView
            android:id="@+id/tvPlayerStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:gravity="center"
            android:text="Sẵn sàng phát"
            android:textColor="#D6E3F3"
            android:textSize="14sp" />

        <!-- FEATURE CARDS -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="76dp"
            android:layout_marginTop="26dp"
            android:gravity="center"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/tvSleepTimer"
                android:layout_width="0dp"
                android:layout_height="70dp"
                android:layout_weight="1"
                android:background="#2D5578"
                android:gravity="center"
                android:text="☾\nHẹn giờ"
                android:textColor="#FFFFFF"
                android:textSize="15sp" />

            <TextView
                android:id="@+id/tvChapter"
                android:layout_width="0dp"
                android:layout_height="70dp"
                android:layout_marginStart="10dp"
                android:layout_weight="1"
                android:background="#2D5578"
                android:gravity="center"
                android:text="☷\nChương"
                android:textColor="#FFFFFF"
                android:textSize="15sp" />

            <TextView
                android:id="@+id/tvSpeed"
                android:layout_width="0dp"
                android:layout_height="70dp"
                android:layout_marginStart="10dp"
                android:layout_weight="1"
                android:background="#2D5578"
                android:gravity="center"
                android:text="1.0x\nTốc độ"
                android:textColor="#FFFFFF"
                android:textSize="15sp"
                android:textStyle="bold" />

        </LinearLayout>

        <!-- SEEKBAR + TIME -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="28dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/tvCurrentTime"
                android:layout_width="64dp"
                android:layout_height="wrap_content"
                android:text="00:00"
                android:textColor="#FFFFFF"
                android:textSize="15sp" />

            <SeekBar
                android:id="@+id/seekAudio"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:progress="0" />

            <TextView
                android:id="@+id/tvTotalTime"
                android:layout_width="64dp"
                android:layout_height="wrap_content"
                android:gravity="end"
                android:text="-00:00"
                android:textColor="#FFFFFF"
                android:textSize="15sp" />

        </LinearLayout>

        <!-- PLAYER CONTROLS -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="104dp"
            android:layout_marginTop="26dp"
            android:gravity="center"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/tvPrevious"
                android:layout_width="46dp"
                android:layout_height="70dp"
                android:gravity="center"
                android:text="|‹"
                android:textColor="#FFFFFF"
                android:textSize="38sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvRewind15"
                android:layout_width="58dp"
                android:layout_height="70dp"
                android:layout_marginStart="12dp"
                android:gravity="center"
                android:text="↺15"
                android:textColor="#FFFFFF"
                android:textSize="27sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvPlayPause"
                android:layout_width="88dp"
                android:layout_height="88dp"
                android:layout_marginStart="18dp"
                android:layout_marginEnd="18dp"
                android:background="#FFFFFF"
                android:gravity="center"
                android:text="▶"
                android:textColor="#123A63"
                android:textSize="42sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvForward30"
                android:layout_width="58dp"
                android:layout_height="70dp"
                android:gravity="center"
                android:text="30↻"
                android:textColor="#FFFFFF"
                android:textSize="27sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvNext"
                android:layout_width="46dp"
                android:layout_height="70dp"
                android:layout_marginStart="12dp"
                android:gravity="center"
                android:text="›|"
                android:textColor="#FFFFFF"
                android:textSize="38sp"
                android:textStyle="bold" />

        </LinearLayout>

        <!-- BUY CARD -->
        <LinearLayout
            android:id="@+id/layoutBuyBook"
            android:layout_width="match_parent"
            android:layout_height="92dp"
            android:layout_marginTop="20dp"
            android:background="#2D5578"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="18dp"
            android:paddingEnd="18dp">

            <TextView
                android:layout_width="42dp"
                android:layout_height="42dp"
                android:background="#456D90"
                android:gravity="center"
                android:text="♪"
                android:textColor="#FFFFFF"
                android:textSize="24sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="14dp"
                android:layout_weight="1"
                android:text="Mua cuốn sách này bằng thẻ Fonos để tiết kiệm tới 80%.\nBạn được sở hữu vĩnh viễn sau khi mua."
                android:textColor="#FFFFFF"
                android:textSize="15sp" />

            <TextView
                android:layout_width="30dp"
                android:layout_height="wrap_content"
                android:gravity="end"
                android:text="›"
                android:textColor="#FFFFFF"
                android:textSize="38sp" />

        </LinearLayout>

    </LinearLayout>

</ScrollView>