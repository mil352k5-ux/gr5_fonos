<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <ImageView
        android:id="@+id/imgPlayerBackground"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="centerCrop" />

    <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#B30C1D37" />

    <ScrollView
        android:id="@+id/playerRoot"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:background="@android:color/transparent">

        <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="24dp"
        android:paddingTop="24dp"
        android:paddingEnd="24dp"
        android:paddingBottom="36dp">

        <!-- TOP BAR -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="56dp">

            <TextView
                android:id="@+id/tvClosePlayer"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:background="@drawable/circle_background_trans"
                android:gravity="center"
                android:text="⌄"
                android:textColor="#FFFFFF"
                android:textSize="32sp"
                android:textStyle="bold"
                android:layout_centerVertical="true" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerInParent="true"
                android:text="Sách nói"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvBookmark"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:layout_alignParentEnd="true"
                android:background="@drawable/circle_background_trans"
                android:gravity="center"
                android:text="📖"
                android:textColor="#FFFFFF"
                android:textSize="22sp"
                android:layout_centerVertical="true" />

        </RelativeLayout>

        <!-- BOOK COVER CARD -->
        <androidx.cardview.widget.CardView
            android:layout_width="220dp"
            android:layout_height="310dp"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="24dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="12dp"
            app:cardBackgroundColor="#DDE6EF">

            <ImageView
                android:id="@+id/imgPlayerCover"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop" />
        </androidx.cardview.widget.CardView>

        <!-- TITLE -->
        <TextView
            android:id="@+id/tvPlayerTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:ellipsize="end"
            android:gravity="center"
            android:maxLines="2"
            android:text="Tên sách"
            android:textColor="#FFFFFF"
            android:textSize="22sp"
            android:textStyle="bold" />

        <!-- AUTHOR -->
        <TextView
            android:id="@+id/tvPlayerAuthor"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:ellipsize="end"
            android:gravity="center"
            android:maxLines="1"
            android:text="Tác giả"
            android:textColor="#FF8A65"
            android:textSize="15sp"
            android:textStyle="bold" />

        <!-- STATUS & FAVORITE IN ONE ROW -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:paddingHorizontal="8dp">

            <TextView
                android:id="@+id/tvPlayerStatus"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_toStartOf="@id/btnAddToPlaylist"
                android:ellipsize="end"
                android:maxLines="2"
                android:text="Đang chuẩn bị phát..."
                android:textColor="#D6E3F3"
                android:textSize="13sp"
                android:layout_centerVertical="true" />

            <TextView
                android:id="@+id/btnAddToPlaylist"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:layout_alignParentEnd="true"
                android:background="@drawable/circle_background_trans"
                android:gravity="center"
                android:text="📂"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:layout_centerVertical="true" />

        </RelativeLayout>

        <!-- SEEKBAR + TIME ROW -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/tvCurrentTime"
                android:layout_width="48dp"
                android:layout_height="wrap_content"
                android:text="00:00"
                android:textColor="#FFFFFF"
                android:textSize="12sp" />

            <SeekBar
                android:id="@+id/seekAudio"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:progress="0"
                android:progressTint="#FF7043"
                android:thumbTint="#FF7043" />

            <TextView
                android:id="@+id/tvTotalTime"
                android:layout_width="48dp"
                android:layout_height="wrap_content"
                android:gravity="end"
                android:text="-00:00"
                android:textColor="#FFFFFF"
                android:textSize="12sp" />

        </LinearLayout>

        <!-- PLAYER CONTROLS (5-BUTTON ROW) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="100dp"
            android:layout_marginTop="20dp"
            android:gravity="center"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/tvPrevious"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:gravity="center"
                android:text="⏮"
                android:textColor="#FFFFFF"
                android:textSize="26sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvRewind15"
                android:layout_width="48dp"
                android:layout_height="44dp"
                android:layout_marginStart="16dp"
                android:gravity="center"
                android:text="↺5"
                android:textColor="#FFFFFF"
                android:textSize="20sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvPlayPause"
                android:layout_width="72dp"
                android:layout_height="72dp"
                android:layout_marginStart="20dp"
                android:layout_marginEnd="20dp"
                android:background="@drawable/bg_player_control_circle"
                android:gravity="center"
                android:text="▶"
                android:textColor="#0C1D37"
                android:textSize="28sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvForward30"
                android:layout_width="48dp"
                android:layout_height="44dp"
                android:layout_marginEnd="16dp"
                android:gravity="center"
                android:text="5↻"
                android:textColor="#FFFFFF"
                android:textSize="20sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvNext"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:gravity="center"
                android:text="⏭"
                android:textColor="#FFFFFF"
                android:textSize="26sp"
                android:textStyle="bold" />

        </LinearLayout>

        <!-- FEATURE CARDS (SLEEP TIMER, CHAPTERS, SPEED) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="28dp"
            android:gravity="center"
            android:orientation="horizontal"
            android:weightSum="3">

            <!-- SLEEP TIMER -->
            <LinearLayout
                android:id="@+id/tvSleepTimer"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🌙"
                    android:textSize="22sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="Hẹn giờ tắt"
                    android:textColor="#D6E3F3"
                    android:textSize="12sp" />
            </LinearLayout>

            <!-- CHAPTERS -->
            <LinearLayout
                android:id="@+id/tvChapter"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="☷"
                    android:textSize="22sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="Chương"
                    android:textColor="#D6E3F3"
                    android:textSize="12sp" />
            </LinearLayout>

            <!-- SPEED -->
            <LinearLayout
                android:id="@+id/tvSpeed"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="1.0x"
                    android:textColor="#FFFFFF"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="Tốc độ"
                    android:textColor="#D6E3F3"
                    android:textSize="12sp" />
            </LinearLayout>

        </LinearLayout>

    </LinearLayout>

</ScrollView>

</FrameLayout>